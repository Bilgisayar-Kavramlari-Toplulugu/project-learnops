# Frontend API base for browser-side requests.
# Keep as /api when using next.config rewrite.
NEXT_PUBLIC_API_BASE_URL=/api

# true  -> login/register/provider aksiyonlari mock davranisla calisir
# false -> auth service endpointlerine gercek istek gider
NEXT_PUBLIC_USE_MOCK_AUTH=true

# Used by next.config.ts rewrite target.
BACKEND_INTERNAL_URL=http://localhost:8000
