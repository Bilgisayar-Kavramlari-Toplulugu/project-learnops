# ===========================
# Bootstrap Environment Variables (.env.example)
# ===========================
# Purpose: Template for Terraform bootstrap inputs (new GCP project + WIF + Secret Manager)
# Instructions: Copy this file to .env and fill in your actual values
# DO NOT commit .env with real secrets to version control!
# ===========================

# ---------------------------
# Terraform bootstrap inputs (non-secret)
# ---------------------------
# You can prefill these using gcloud (examples):
#   gcloud billing accounts list --format='value(name)'
#   gcloud config get-value account

# ===========================
# GCP Configuration
# ===========================
GOOGLE_PROJECT_ID=learnops-staging
BILLING_ACCOUNT=

# ===========================
# GitHub Configuration
# ===========================
GITHUB_ACTIONS_SA_NAME=learnops-stg-gha-sa
GITHUB_ORG=Bilgisayar-Kavramlari-Toplulugu
GITHUB_REPO=project-learnops

# ===========================
# Terraform Configuration
# ===========================
TERRAFORM_STATE_BUCKET_NAME=project-learnops-staging-terraform-statefiles

# ===========================
# Application Secrets
# ===========================
JWT_SECRET=
SESSION_SECRET=
TOKEN_ENCRYPTION_KEY=

# ===========================
# OAuth2 - Google
# ===========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================
# OAuth2 - GitHub
# ===========================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================
# OAuth2 - LinkedIn
# ===========================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
