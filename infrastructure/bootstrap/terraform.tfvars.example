# ===========================
# Bootstrap Configuration Example
# Copy this file to terraform.tfvars and fill in your values
# ===========================

# Your GCP Billing Account ID (format: 123456-ABCDEF-123456)
billing_account = "BILLING_ACCOUNT"

# Project ID for the staging environment
# Must be globally unique within GCP
project_id = "learnops-staging"

# GCP region for resources
region = "europe-west3"

# Service Account name for GitHub Actions
# Must be 6-30 characters, lowercase letters, numbers, hyphens
github_actions_sa_name = "learnops-stg-gha-sa"

# GitHub organization or username
github_org = "Bilgisayar-Kavramlari-Toplulugu"

# GitHub repository name (without org)
github_repo = "project-learnops"

# Terraform state bucket name (must be globally unique in GCS)
# This will be created manually before running terraform
terraform_state_bucket_name = "YOUR_BUCKET_NAME"

# ===========================
# OAuth2 Configuration
# These domains are used to generate OAuth redirect URIs
# Set to your actual frontend/backend domains
# ===========================

# Frontend domain for OAuth redirect URIs
# Example: learnops-staging.findmywayapp.com
frontend_domain = "learnops-staging.findmywayapp.com"

# Backend domain or Cloud Run URL for OAuth redirect URIs
# Leave empty if backend doesn't need OAuth callbacks
backend_domain = ""

# Paths to append to domains for OAuth redirects (default shown)
# oauth_redirect_uri_paths = ["/auth/callback", "/callback"]

# Environment secrets from .env file
# These will be uploaded to Google Secret Manager
# DO NOT commit this file with actual values!
# Instead, load them from your .env file or pass them via CLI
env_secrets = {
  # JWT
  JWT_SECRET = "from-.env-file"

  # Session
  SESSION_SECRET = "from-.env-file"

  # OAuth - Google
  GOOGLE_CLIENT_ID     = "from-.env-file"
  GOOGLE_CLIENT_SECRET = "from-.env-file"

  # OAuth - GitHub
  GITHUB_CLIENT_ID     = "from-.env-file"
  GITHUB_CLIENT_SECRET = "from-.env-file"

  # OAuth - LinkedIn
  LINKEDIN_CLIENT_ID     = "from-.env-file"
  LINKEDIN_CLIENT_SECRET = "from-.env-file"

  # Token Encryption
  TOKEN_ENCRYPTION_KEY = "from-.env-file"
}
