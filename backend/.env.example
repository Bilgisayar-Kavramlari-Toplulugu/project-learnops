# ===========================================================================
# LearnOps Environment Variables Template
# ===========================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in all values with your own
# 3. Never commit .env (it contains secrets!)
# ===========================================================================

# Database Configuration
# Note: When running with docker-compose, use 'db' as hostname
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/learnops_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=learnops_db

# JWT Configuration (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Token Encryption (32 bytes for AES-256)
TOKEN_ENCRYPTION_KEY=your-32-byte-encryption-key-generate-with-openssl-rand-hex-32

# OAuth 2.0 Credentials
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Allowed Origins (CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Environment
ENVIRONMENT=development  # development | staging | production
